# Database credentials (used by docker-compose)
POSTGRES_USER=urlshortener
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=urlshortener

# Backend connection string (must match above credentials)
DATABASE_URL=postgresql://urlshortener:change_me_in_production@localhost:5432/urlshortener

# Application
BASE_URL=http://localhost:8000
ENVIRONMENT=development

# CORS - JSON array of allowed origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
