# Production environment for Docker Compose
# Copy to .env and update values before deploying

# Domain (required)
DOMAIN=s.example.com

# PostgreSQL (required)
POSTGRES_USER=urlshortener
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=urlshortener

# Caddy - Standalone (auto-SSL, default):
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
# CADDY_SCHEME=https  # default, Caddy handles SSL

# Caddy - Behind Apache:
# CADDY_HTTP_PORT=8080
# CADDY_HTTPS_PORT=8443
# CADDY_SCHEME=http  # Apache handles SSL
